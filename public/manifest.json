{
    "name": "oneHR - Comprehensive Human Resources Management System",
    "short_name": "oneHR",
    "description": "A comprehensive HR solution covering the full employee lifecycle from onboarding to offboarding",
    "start_url": "/",
    "display": "standalone",
    "background_color": "#ffffff",
    "theme_color": "#000000",
    "orientation": "portrait-primary",
    "scope": "/",
    "lang": "en",
    "dir": "ltr",
    "categories": ["business", "productivity", "human resources"],
    "icons": [
        {
            "src": "/logo.png",
            "sizes": "192x192",
            "type": "image/png",
            "purpose": "any maskable"
        },
        {
            "src": "/logo.png",
            "sizes": "512x512",
            "type": "image/png",
            "purpose": "any maskable"
        },
        {
            "src": "/favicon.ico",
            "sizes": "16x16 32x32 48x48",
            "type": "image/x-icon"
        }
    ],
    "shortcuts": [
        {
            "name": "Dashboard",
            "short_name": "Dashboard",
            "description": "View your HR dashboard",
            "url": "/dashboard",
            "icons": [
                {
                    "src": "/logo.png",
                    "sizes": "96x96"
                }
            ]
        },
        {
            "name": "Employees",
            "short_name": "Employees",
            "description": "Manage employees",
            "url": "/employees",
            "icons": [
                {
                    "src": "/logo.png",
                    "sizes": "96x96"
                }
            ]
        },
        {
            "name": "Leave Management",
            "short_name": "Leave",
            "description": "Manage leave requests",
            "url": "/leave_management",
            "icons": [
                {
                    "src": "/logo.png",
                    "sizes": "96x96"
                }
            ]
        }
    ],
    "related_applications": [],
    "prefer_related_applications": false,
    "edge_side_panel": {
        "preferred_width": 400
    },
    "launch_handler": {
        "client_mode": "navigate-existing"
    },
    "handle_links": "preferred",
    "protocol_handlers": [
        {
            "protocol": "web+onehr",
            "url": "/?action=%s"
        }
    ],
    "file_handlers": [
        {
            "action": "/upload",
            "accept": {
                "application/pdf": [".pdf"],
                "image/*": [".png", ".jpg", ".jpeg", ".gif"]
            }
        }
    ]
}

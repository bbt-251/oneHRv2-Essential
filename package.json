{
  "name": "oneHRv2",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3011",
    "build": "pnpm run format && pnpm run lint:fix && pnpm run lint && next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "fix:all": "npm run lint:fix && npm run format",
    "type-check": "tsc --noEmit",
    "backfill-weaviate": "tsx scripts/backfill-weaviate.ts",
    "sync-weaviate": "tsx scripts/backfill-weaviate.ts",
    "test-recruiter-ai": "npx --yes tsx scripts/test-recruiter-ai.ts",
    "migrate:emails": "npx tsx scripts/migrate-firebase-auth-emails.ts",
    "migrate:emails:execute": "npx tsx scripts/migrate-firebase-auth-emails.ts --execute",
    "test:migration": "npx tsx scripts/test-migration.ts",
    "manual:env:check": "node -e \"const vars=['MANUAL_BACKEND_URL','MANUAL_AUTH_JWT_SECRET','MANUAL_MONGODB_URI','MANUAL_REDIS_URL']; const missing=vars.filter(v=>!process.env[v]); if(missing.length){console.warn('Missing env vars:',missing.join(',')); process.exit(1);} console.log('Manual backend env looks good.');\"",
    "test:manual:phase2": "npx tsx lib/backend/manual/phase-2-tests.ts",
    "test:manual:phase3": "npx tsx lib/backend/manual/phase-3-tests.ts",
    "test:manual:phase8": "npx tsx lib/backend/manual/phase-8-tests.ts"
    "test:manual:phase6": "npx tsx lib/backend/manual/phase-6-tests.ts",
    "test:manual:phase5": "npx tsx lib/backend/manual/phase-5-tests.ts",
